@startuml UserManagementClassDiagram
title User Management - Class Diagram
!theme plain
skinparam classBackgroundColor #E8F5E9
skinparam classBorderColor #388E3C
skinparam arrowColor #333

class UserController {
    -userService: UserService
    --
    +getProfile(@Headers() authorization): Promise<Response>
    +updateProfile(@Body() dto: UpdateProfileDto): Promise<Response>
    +addAddress(@Body() dto: CreateAddressDto): Promise<Response>
    +updateAddress(@Param('id') id: string, @Body() dto: UpdateAddressDto): Promise<Response>
    +removeAddress(@Param('id') id: string): Promise<Response>
    +setDefaultAddress(@Param('id') id: string): Promise<Response>
    +updateUser(@Param('id') id: string, @Body() dto: UpdateUserDto): Promise<Response>
}

class UserService {
    -userRepository: UserRepository
    --
    +getProfile(userId: string): Promise<UserResponseDto>
    +updateProfile(userId: string, dto: UpdateProfileDto): Promise<User>
    +addAddress(userId: string, dto: CreateAddressDto): Promise<Address>
    +updateAddress(userId: string, addressId: string, dto: UpdateAddressDto): Promise<Address>
    +removeAddress(userId: string, addressId: string): Promise<void>
    +setDefaultAddress(userId: string, addressId: string): Promise<void>
    -clearDefaultAddresses(userId: string): Promise<void>
}

class UserRepository {
    --
    +findOne(id: string): Promise<User>
    +findByEmail(email: string): Promise<User>
    +update(id: string, data: UpdateUserDto): Promise<User>
    +addAddress(userId: string, dto: CreateAddressDto): Promise<Address>
    +updateAddress(addressId: string, dto: UpdateAddressDto): Promise<Address>
    +removeAddress(addressId: string): Promise<void>
}

class UpdateProfileDto {
    +fullName?: string
    +phone?: string
    +avatar?: string
    +preferences?: UserPreferences
}

class CreateAddressDto {
    +fullName: string
    +phone: string
    +address: string
    +city: string
    +district: string
    +ward: string
    +isDefault: boolean
}

class UserResponseDto {
    +id: string
    +email: string
    +fullName: string
    +phone: string
    +avatar: string
    +role: UserRole
    +status: UserStatus
    +addresses: AddressResponseDto[]
}

UserController --> UserService: delegates
UserService --> UserRepository: persists
UserRepository --> User: maps
UpdateProfileDto ..> UserService: input to
CreateAddressDto ..> UserService: input to
UserResponseDto ..> User: maps from

@enduml
