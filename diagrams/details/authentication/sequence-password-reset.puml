@startuml PasswordResetSequence
title Password Reset - Sequence Diagram

actor ":User" as user
participant ":AuthController" as controller
participant ":AuthService" as authService
participant ":EmailService" as emailService
participant ":UserRepository" as userRepo
database ":Database" as db

' ════════════════════════════════════════════════════════════════════════════════════
' STEP 1: Request Password Reset
' ════════════════════════════════════════════════════════════════════════════════════

user -> controller: POST /auth/forgot-password\n{email}
activate controller

controller -> authService: forgotPassword(email)
activate authService

authService -> userRepo: findByEmail(email)
activate userRepo
userRepo -> db: SELECT user\nWHERE email = email
db --> userRepo: User
userRepo --> authService: User
deactivate userRepo

alt [Email not found]
    authService --> controller: 200 OK\n(If email exists, reset link sent)
    ' Security: Don't reveal if email exists
else [Email found]
    authService -> authService: generateResetToken()
    authService -> authService: hashToken(token)

    authService -> userRepo: save(user)
    activate userRepo
    userRepo -> db: UPDATE user\nSET resetToken = hashedToken,\nresetExpires = NOW() + 1h
    db --> userRepo: Updated
    userRepo --> authService: Updated
    deactivate userRepo

    authService -> emailService: sendPasswordResetEmail(user, token)
    activate emailService
    emailService -> emailService: Build reset email\nwith reset link
    emailService -> emailService: Send via SMTP
    emailService --> authService: Sent
    deactivate emailService

    authService --> controller: 200 OK\n(If email exists, reset link sent)
end

controller --> user: 200 OK\nIf email exists, reset link sent
deactivate controller

' ════════════════════════════════════════════════════════════════════════════════════
' STEP 2: Reset Password with Token
' ════════════════════════════════════════════════════════════════════════════════════

user -> controller: POST /auth/reset-password\n{token, newPassword}
activate controller

controller -> authService: resetPassword(token, newPassword)
activate authService

authService -> userRepo: findByResetToken(token)
activate userRepo
userRepo -> db: SELECT user\nWHERE resetToken = hashedToken
db --> userRepo: User
userRepo --> authService: User
deactivate userRepo

alt [Token not found / Invalid]
    authService --> controller: 400 BAD REQUEST\n(Invalid reset token)
else [Token found]
    authService -> authService: verifyTokenExpiry(user.resetExpires)

    alt [Token expired]
        authService --> controller: 400 BAD REQUEST\n(Reset token expired,\nplease request a new one)
    else [Token valid]
        authService -> authService: validatePasswordStrength(newPassword)
        authService -> authService: hashPassword(newPassword)

        authService -> db: TRANSACTION START
        activate db

        authService -> userRepo: updatePassword(user.id, newPassword)
        activate userRepo
        userRepo -> db: UPDATE user\nSET passwordHash = newHash,\nresetToken = null,\nresetExpires = null,\nstatus = 'ACTIVE',\npasswordChangedAt = NOW()
        db --> userRepo: Updated
        userRepo --> authService: Updated
        deactivate userRepo

        authService -> db: COMMIT
        deactivate db

        authService -> authService: invalidateAllSessions(user.id)
        authService --> controller: 200 OK\n{message: 'Password reset successful'}
    end
end

controller --> user: 200 OK\nPassword reset successful\nPlease login with new password
deactivate controller


@enduml
