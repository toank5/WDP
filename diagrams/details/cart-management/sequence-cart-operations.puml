@startuml CartOperationsSequence
title Cart Operations - Sequence Diagram

actor ":Customer" as customer
participant ":CartController" as controller
participant ":JwtAuthGuard" as authGuard
participant ":CartService" as cartService
participant ":ProductService" as productService
participant ":CartRepository" as cartRepo
database ":Database" as db

' ════════════════════════════════════════════════════════════════════════════════════
' SCENARIO 1: Get Cart
' ════════════════════════════════════════════════════════════════════════════════════

customer -> controller: GET /cart
activate controller

controller -> authGuard: canActivate(context)
activate authGuard
authGuard --> controller: true
deactivate authGuard

controller -> cartService: getCart(userId)
activate cartService

cartService -> cartRepo: findCartByUserId(userId)
activate cartRepo
cartRepo -> db: SELECT cart WITH items\nWHERE userId = userId
db --> cartRepo: Cart
cartRepo --> cartService: Cart
deactivate cartRepo

alt [Cart exists]
    cartService -> cartService: calculateTotals(cart.items)
    cartService -> productService: enrichWithProductInfo(cart.items)
    activate productService
    productService --> cartService: Items with prices
    deactivate productService
else [Cart doesn't exist]
    cartService -> cartRepo: create(userId)
    activate cartRepo
    cartRepo -> db: INSERT cart\nSET userId = userId
    db --> cartRepo: New Cart
    cartRepo --> cartService: Empty Cart
    deactivate cartRepo
end

cartService --> controller: 200 OK\n{items, subtotal, itemCount}
deactivate cartService

controller --> customer: 200 OK\nCart data
deactivate controller

' ════════════════════════════════════════════════════════════════════════════════════
' SCENARIO 2: Add Item to Cart
' ════════════════════════════════════════════════════════════════════════════════════

customer -> controller: POST /cart/items\n{variantId, quantity}
activate controller

controller -> cartService: addItem(userId, variantId, quantity)
activate cartService

cartService -> productService: validateVariant(variantId)
activate productService
productService -> productService: checkVariantExists(variantId)
productService -> productService: checkVariantInStock(variantId, quantity)
productService --> cartService: Valid
deactivate productService

cartService -> cartRepo: findCartByUserId(userId)
activate cartRepo
cartRepo -> db: SELECT cart WITH items
db --> cartRepo: Cart
cartRepo --> cartService: Cart
deactivate cartRepo

alt [Cart exists]
    alt [Item already exists in cart]
        cartService -> cartService: updateItemQuantity(cart, variantId, quantity)
    else [New item]
        cartService -> cartRepo: addItem(cartId, variantId, quantity)
        activate cartRepo
        cartRepo -> db: INSERT cart_item\nSET cartId, variantId, quantity
        db --> cartRepo: CartItem
        cartRepo --> cartService: CartItem
        deactivate cartRepo
    end
else [No cart exists]
    cartService -> cartRepo: createCartWithItem(userId, variantId, quantity)
    activate cartRepo
    cartRepo -> db: TRANSACTION START
    activate db
    cartRepo -> db: INSERT cart
    cartRepo -> db: INSERT cart_item
    cartRepo -> db: COMMIT
    deactivate db
    cartRepo --> cartService: Cart with item
    deactivate cartRepo
end

cartService --> controller: 201 CREATED\n{cart}
deactivate cartService

controller --> customer: 201 CREATED\nItem added to cart
deactivate controller

' ════════════════════════════════════════════════════════════════════════════════════
' SCENARIO 3: Update Item Quantity
' ════════════════════════════════════════════════════════════════════════════════════

customer -> controller: PUT /cart/items/:itemId\n{quantity}
activate controller

controller -> cartService: updateItem(userId, itemId, quantity)
activate cartService

cartService -> cartRepo: findCartItemById(itemId)
activate cartRepo
cartRepo -> db: SELECT cart_item\nWITH cart
db --> cartRepo: CartItem
cartRepo --> cartService: CartItem
deactivate cartRepo

alt [Item not found]
    cartService --> controller: 404 NOT FOUND
else [Item belongs to different user]
    cartService --> controller: 403 FORBIDDEN
else [Valid request]
    alt [Quantity = 0]
        cartService -> cartRepo: removeItem(itemId)
        activate cartRepo
        cartRepo -> db: DELETE cart_item\nWHERE id = itemId
        db --> cartRepo: Deleted
        cartRepo --> cartService: Done
        deactivate cartRepo
    else [Quantity > 0]
        cartService -> productService: checkStock(variantId, quantity)
        activate productService
        productService --> cartService: In stock
        deactivate productService

        cartService -> cartRepo: updateItemQuantity(itemId, quantity)
        activate cartRepo
        cartRepo -> db: UPDATE cart_item\nSET quantity = quantity
        db --> cartRepo: Updated
        cartRepo --> cartService: Updated
        deactivate cartRepo
    end

    cartService --> controller: 200 OK\n{cart}
end

controller --> customer: 200 OK\nCart updated
deactivate controller

' ════════════════════════════════════════════════════════════════════════════════════
' SCENARIO 4: Remove Item
' ════════════════════════════════════════════════════════════════════════════════════

customer -> controller: DELETE /cart/items/:itemId
activate controller

controller -> cartService: removeItem(userId, itemId)
activate cartService

cartService -> cartRepo: findCartItemById(itemId)
activate cartRepo
cartRepo -> db: SELECT cart_item\nWITH cart
db --> cartRepo: CartItem
cartRepo --> cartService: CartItem
deactivate cartRepo

alt [Item not found]
    cartService --> controller: 404 NOT FOUND
else [Item belongs to different user]
    cartService --> controller: 403 FORBIDDEN
else [Valid request]
    cartService -> cartRepo: removeItem(itemId)
    activate cartRepo
    cartRepo -> db: DELETE cart_item\nWHERE id = itemId
    db --> cartRepo: Deleted
    cartRepo --> cartService: Done
    deactivate cartRepo

    cartService --> controller: 200 OK\n{message: 'Item removed'}
end

controller --> customer: 200 OK\nItem removed from cart
deactivate controller

' ════════════════════════════════════════════════════════════════════════════════════
' SCENARIO 5: Clear Cart
' ════════════════════════════════════════════════════════════════════════════════════

customer -> controller: DELETE /cart
activate controller

controller -> cartService: clearCart(userId)
activate cartService

cartService -> cartRepo: findCartByUserId(userId)
activate cartRepo
cartRepo -> db: SELECT cart\nWHERE userId = userId
db --> cartRepo: Cart
cartRepo --> cartService: Cart
deactivate cartRepo

cartService -> cartRepo: clearCartItems(cartId)
activate cartRepo
cartRepo -> db: DELETE cart_item\nWHERE cartId = cartId
db --> cartRepo: Cleared
cartRepo --> cartService: Done
deactivate cartRepo

cartService --> controller: 200 OK\n{message: 'Cart cleared'}
deactivate cartService

controller --> customer: 200 OK\nCart cleared
deactivate controller

@enduml
