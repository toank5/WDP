@startuml CreatePreorderSequence
title Create Preorder - Sequence Diagram

actor ":Customer" as customer
participant ":PreorderController" as controller
participant ":JwtAuthGuard" as authGuard
participant ":PreorderService" as preorderService
participant ":ProductService" as productService
participant ":InventoryService" as inventoryService
participant ":EmailService" as emailService
participant ":PreorderRepository" as preorderRepo
database ":Database" as db

customer -> controller: POST /preorders\n{productId, quantity, deposit}
activate controller

controller -> authGuard: canActivate(context)
activate authGuard
authGuard --> controller: true
deactivate authGuard

controller -> preorderService: createPreorder(userId, preorderDto)
activate preorderService

preorderService -> productService: validateProduct(productId)
activate productService
productService -> productService: checkProductAvailableForPreorder(productId)
productService --> preorderService: Valid
deactivate productService

preorderService -> inventoryService: checkPreorderAvailability(productId, quantity)
activate inventoryService
inventoryService --> preorderService: Available
deactivate inventoryService

preorderService -> preorderRepo: create(preorderData)
activate preorderRepo
preorderRepo -> db: INSERT preorder\nSET userId, productId, quantity, deposit\nstatus = 'PENDING'
db --> preorderRepo: Preorder
preorderRepo --> preorderService: Preorder
deactivate preorderRepo

preorderService -> emailService: sendPreorderConfirmation(preorder)
activate emailService
emailService -> emailService: Build confirmation email
emailService -> emailService: Send to customer
emailService --> preorderService: Sent
deactivate emailService

preorderService --> controller: 201 CREATED\n{preorderNumber, estimatedDelivery}
deactivate preorderService

controller --> customer: 201 CREATED\nPreorder created
deactivate controller

@enduml
