@startuml MediaManagementClassDiagram
title Media Management - Class Diagram
!theme plain
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #7B1FA2
skinparam arrowColor #333

class MediaController {
    -mediaService: MediaService
    --
    +uploadImages2D(@Files() files: File[]): Promise<Response>
    +uploadModels3D(@Files() files: File[]): Promise<Response>
    +deleteMedia(@Param('publicId') publicId: string): Promise<Response>
    +getMediaInfo(@Param('publicId') publicId: string): Promise<Response>
}

class MediaService {
    -cloudinaryService: CloudinaryService
    -mediaRepository: MediaRepository
    --
    +uploadImages2D(files: File[]): Promise<UploadResult>
    +uploadModels3D(files: File[]): Promise<UploadResult>
    +deleteMedia(publicId: string): Promise<void>
    +validateFiles(files: File[], allowedTypes: string[]): boolean
    +validateFileSize(files: File[], maxSize: number): boolean
}

class CloudinaryService {
    -cloudinary: any
    --
    +uploadImages(files: File[], options: UploadOptions): Promise<string[]>
    +uploadModels(files: File[], options: UploadOptions): Promise<ModelUploadResult[]>
    +deleteResource(publicId: string): Promise<void>
    -processImage(file: File): Promise<ProcessedFile>
    -process3DModel(file: File): Promise<ProcessedModel>
}

class MediaRepository {
    --
    +create(mediaData: CreateMediaDto): Promise<MediaRecord>
    +findByPublicId(publicId: string): Promise<MediaRecord>
    +delete(publicId: string): Promise<void>
    -invalidateCache(publicId: string): void
}

class MediaRecord {
    -id: string
    -publicId: string
    -type: MediaType
    -url: string
    -thumbnailUrl: string
    -width: number
    -height: number
    -format: string
    -size: number
    -metadata: ModelMetadata
    -uploadedBy: string
    -createdAt: Date
}

class ModelMetadata {
    +vertices: number
    +faces: number
    +materials: number
    +animations: number
}

class UploadResult {
    +urls: string[]
    +thumbnails: string[]
    +publicIds: string[]
}

class ModelUploadResult {
    +urls: string[]
    +previews: string[]
    +metadata: ModelMetadata[]
    +publicIds: string[]
}

enum MediaType {
    IMAGE_2D
    MODEL_3D
    VIDEO
    THUMBNAIL
}

MediaController --> MediaService: delegates
MediaService --> CloudinaryService: uploads
MediaService --> MediaRepository: persists
CloudinaryService --> MediaRecord: creates
MediaRepository --> MediaRecord: maps
UploadResult ..> MediaService: output from
ModelUploadResult ..> MediaService: output from

@enduml
