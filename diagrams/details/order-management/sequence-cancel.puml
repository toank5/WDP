@startuml OrderCancelSequence
title Order Cancellation - Sequence Diagram

actor ":Customer/Staff" as actor
participant ":OrderController" as controller
participant ":JwtAuthGuard" as authGuard
participant ":RbacGuard" as rbacGuard
participant ":OrderService" as orderService
participant ":InventoryService" as inventoryService
participant ":VNPayService" as vnpayService
participant ":EmailService" as emailService
participant ":OrderRepository" as orderRepo
database ":Database" as db

actor -> controller: POST /orders/:id/cancel\n{reason}
activate controller

controller -> authGuard: canActivate(context)
activate authGuard
authGuard --> controller: true (JWT valid)
deactivate authGuard

alt [Staff cancelling - RBAC check]
    controller -> rbacGuard: canActivate(context)
    activate rbacGuard
    rbacGuard --> controller: true (Staff authorized)
    deactivate rbacGuard
end

controller -> orderService: cancelOrder(orderId, userId, userRole, reason)
activate orderService

orderService -> orderRepo: findOne(orderId)
activate orderRepo
orderRepo -> db: SELECT order
db --> orderRepo: Order
orderRepo --> orderService: Order
deactivate orderRepo

alt [Order not found]
    orderService --> controller: 404 NOT FOUND\n(Order not found)
else [Order already cancelled/completed]
    orderService --> controller: 400 BAD REQUEST\n(Order cannot be cancelled)
else [Customer cancelling - ownership check]
    orderService -> orderService: validateOwnership(order.customerId === userId)
    alt [Not owner]
        orderService --> controller: 403 FORBIDDEN\n(Not your order)
    end
else [Order can be cancelled]
    orderService -> orderService: validateCancellableStatus(order.status)

    orderService -> db: TRANSACTION START
    activate db

    orderService -> orderRepo: updateStatus(orderId, CANCELLED, reason)
    activate orderRepo
    orderRepo -> db: UPDATE order\nSET status = 'CANCELLED',\ncancelledAt = NOW(),\ncancelReason = reason
    db --> orderRepo: Updated Order
    orderRepo --> orderService: Updated Order
    deactivate orderRepo

    alt [Order was PAID - Refund needed]
        orderService -> vnpayService: initiateRefund(order)
        activate vnpayService
        vnpayService -> vnpayService: Build refund request
        vnpayService -> vnpayService: Call VNPAY API
        vnpayService --> orderService: Refund transaction ID
        deactivate vnpayService

        orderService -> orderRepo: updateRefundInfo(orderId, refundTxnId)
        activate orderRepo
        orderRepo -> db: UPDATE order\nSET refundTxnId = txnId
        db --> orderRepo: Updated
        orderRepo --> orderService: Updated
        deactivate orderRepo
    end

    orderService -> inventoryService: releaseReservation(orderId)
    activate inventoryService
    inventoryService -> db: UPDATE inventory\n(reserved -> available)
    db --> inventoryService: Released
    inventoryService --> orderService: Released
    deactivate inventoryService

    orderService -> db: COMMIT
    deactivate db

    orderService -> emailService: sendCancellationEmail(order, reason)
    activate emailService
    emailService -> emailService: Build cancellation email
    alt [Refund initiated]
        emailService -> emailService: Include refund details
    end
    emailService -> emailService: Send via SMTP
    emailService --> orderService: Sent
    deactivate emailService

    orderService --> controller: 200 OK\n{orderNumber, status: CANCELLED}
end

controller --> actor: 200 OK\nOrder cancelled successfully
deactivate controller


@enduml
