@startuml ProductCreateSequence
title Product Creation - Sequence Diagram

actor ":Manager/Admin" as admin
participant ":ProductController" as controller
participant ":JwtAuthGuard" as authGuard
participant ":RbacGuard" as rbacGuard
participant ":ProductService" as productService
participant ":MediaService" as mediaService
participant ":InventoryService" as inventoryService
participant ":ProductRepository" as productRepo
participant ":VariantRepository" as variantRepo
database ":Database" as db

admin -> controller: POST /products\n(CreateProductDto)
activate controller

controller -> authGuard: canActivate(context)
activate authGuard
authGuard --> controller: true (JWT valid)
deactivate authGuard

controller -> rbacGuard: canActivate(context)
activate rbacGuard
rbacGuard -> rbacGuard: checkRole(MANAGER/ADMIN)
rbacGuard --> controller: true (Authorized)
deactivate rbacGuard

controller -> productService: create(createDto, userId)
activate productService

productService -> productService: validateProductData(createDto)
productService -> productService: validateCategory(createDto.category)

alt [Category is FRAMES]
    productService -> productService: validateFrameProperties(createDto)
else [Category is LENSES]
    productService -> productService: validateLensProperties(createDto)
else [Category is SERVICES]
    productService -> productService: validateServiceProperties(createDto)
end

alt [Images provided]
    productService -> mediaService: uploadAndValidateImages(createDto.images)
    activate mediaService
    mediaService -> mediaService: Validate file types\n(2D: jpg, png; 3D: glb, obj)
    mediaService -> mediaService: Upload to CDN\n(Cloudinary)
    mediaService --> productService: Uploaded image URLs
    deactivate mediaService
end

productService -> db: TRANSACTION START
activate db

productService -> productRepo: create(productData)
activate productRepo
productRepo -> db: INSERT product\nSET status = 'DRAFT',\ncreatedBy = userId
db --> productRepo: Product
productRepo --> productService: Product
deactivate productRepo

alt [Variants provided]
    productService -> variantRepo: createVariants(productId, createDto.variants)
    activate variantRepo
    loop for each variant
        variantRepo -> db: INSERT product_variant\nSET productId, sku, price, stock
        db --> variantRepo: Variant
    end
    variantRepo --> productService: Variants[]
    deactivate variantRepo
end

productService -> inventoryService: initializeInventory(variants)
activate inventoryService
inventoryService -> db: INSERT inventory\nFOR each variant
db --> inventoryService: Initialized
inventoryService --> productService: Done
deactivate inventoryService

productService -> db: COMMIT
deactivate db

productService --> controller: 201 CREATED\n{product, variants}
deactivate productService

controller --> admin: 201 CREATED\nProduct created successfully
deactivate controller

note right of admin
  Product created with DRAFT status
  Images uploaded to CDN
  Inventory initialized
  Ready for review and publish
end note

@enduml
