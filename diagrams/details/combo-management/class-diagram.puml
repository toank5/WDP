@startuml ComboManagementClassDiagram
title Combo (Frame + Lens) Management - Class Diagram
!theme plain
skinparam classBackgroundColor #E1F5FE
skinparam classBorderColor #0288D1
skinparam arrowColor #333

class ComboController {
    -comboService: ComboService
    --
    +create(@Body() dto: CreateComboDto): Promise<Response>
    +findAll(@Query() filters: ComboFiltersDto): Promise<Response>
    +findOne(@Param('id') id: string): Promise<Response>
    +update(@Param('id') id: string, @Body() dto: UpdateComboDto): Promise<Response>
    +remove(@Param('id') id: string): Promise<Response>
    +getCombosForProduct(@Param('productId') productId: string): Promise<Response>
}

class ComboService {
    -comboRepository: ComboRepository
    -productService: ProductService
    --
    +create(createDto: CreateComboDto, userId: string): Promise<Combo>
    +calculateComboPrice(framePrice: number, lensPrice: number, discount: number): number
    +validateDiscountReason(discount: number, reason: string): boolean
    +getCombosForProduct(productId: string): Promise<ComboWithProductsDto[]>
}

class ComboRepository {
    --
    +findOne(id: string): Promise<Combo>
    +findByFrameOrLens(productId: string): Promise<Combo[]>
    +findActive(): Promise<Combo[]>
    +create(comboData: CreateComboDto): Promise<Combo>
    +update(id: string, data: UpdateComboDto): Promise<Combo>
}

class Combo {
    -id: string
    -frameId: string
    -lensId: string
    -discount: number
    -discountType: DiscountType
    -discountReason: string
    -status: ComboStatus
    -validFrom: Date
    -validUntil: Date
}

class CreateComboDto {
    +frameId: string
    +lensId: string
    +discount: number
    +discountType: DiscountType
    +discountReason: string
    +validFrom: Date
    +validUntil: Date
}

class ComboWithProductsDto {
    +frame: ProductInfo
    +lens: ProductInfo
    +originalPrice: number
    +comboPrice: number
    +savings: number
    +discount: number
}

enum DiscountType {
    PERCENTAGE
    FIXED_AMOUNT
}

enum ComboStatus {
    ACTIVE
    INACTIVE
    EXPIRED
}

ComboController --> ComboService: delegates
ComboService --> ComboRepository: persists
ComboService --> ProductService: validates
ComboRepository --> Combo: maps
CreateComboDto ..> Combo: maps to
ComboWithProductsDto ..> Combo: maps from

@enduml
