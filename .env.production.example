# Production Environment Configuration
# Copy this file to .env.production and fill in your values

# Node Environment
NODE_ENV=production

# MongoDB Atlas Configuration
# Get these from your MongoDB Atlas dashboard
DB_USERNAME=your-atlas-username
DB_PASSWORD=your-atlas-password
DB_HOST=your-cluster-name.xxxxx.mongodb.net
DB_NAME=wdp

# JWT Secrets (IMPORTANT: Use strong, unique secrets in production)
JWT_ACCESS_TOKEN_SECRET=change-this-to-a-strong-secret-key
JWT_ACCESS_TOKEN_EXPIRATION=8000m
JWT_REFRESH_TOKEN_SECRET=change-this-to-another-strong-secret-key
JWT_REFRESH_TOKEN_EXPIRATION=7d
JWT_VERIFY_EMAIL_TOKEN_SECRET=change-this-to-verification-secret-key
JWT_VERIFY_TOKEN_EXPIRATION=24h
JWT_RESET_PASSWORD_TOKEN_SECRET=change-this-to-reset-secret-key
JWT_RESET_PASSWORD_TOKEN_EXPIRATION=1h

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Upload size limits (in MB)
UPLOAD_MAX_SIZE_2D=10
UPLOAD_MAX_SIZE_3D=10

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=your-email@gmail.com
FRONTEND_URL=https://your-frontend-domain.com

# VNPAY Configuration
VNPAY_TMN_CODE=YOUR_TMN_CODE
VNPAY_HASH_SECRET=YOUR_HASH_SECRET
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_SANDBOX=true
# For production VNPAY, change SANDBOX to false and use production URL
VNPAY_RETURN_URL=https://your-frontend-domain.com/checkout/vnpay-return
VNPAY_IPN_URL=https://your-backend-domain.com/checkout/vnpay-ipn
